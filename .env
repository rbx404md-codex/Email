# ============================================
# 🌧️ Cloud9 MailBomb Bot - Environment Variables
# ============================================

# ----- Telegram Bot -----
# Required: Your bot token from @BotFather
BOT_TOKEN=8920673916:AAGBabrveB7IJCGATNmSBL-XtG-w2aRu82c

# Required: Admin Telegram user IDs (comma separated)
ADMIN_IDS=7294948308,

# ----- OxaPay Payment Gateway -----
# Required: Your OxaPay merchant API key
OXAPAY_MERCHANT_API_KEY=your_oxapay_api_key_here

# ----- Database -----
# Optional: Default is SQLite (sqlite:///cloud9.db)
# For PostgreSQL: postgresql://user:pass@localhost/cloud9
DATABASE_URL=sqlite:///cloud9.db

# ----- AWS SES (Optional - for real email sending) -----
# Only needed if USE_SES=true
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
SES_SENDER_EMAIL=sender@yourdomain.com

# Set to "true" to enable AWS SES, "false" to use SMTP
USE_SES=false

# ----- SMTP Settings (if not using SES) -----
# These are auto-detected from email domain, but can be overridden
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
